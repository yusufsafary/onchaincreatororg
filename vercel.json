{
  "framework": null,
  "installCommand": "npm install -g pnpm@10 && pnpm install",
  "buildCommand": "pnpm --filter @workspace/onchaincreator run build",
  "outputDirectory": "artifacts/onchaincreator/dist/public",
  "env": {
    "BASE_PATH": "/"
  },
  "rewrites": [
    {
      "source": "/((?!api(?:/|$)|\\.well-known(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
